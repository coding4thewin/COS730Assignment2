@{
    ViewData["Title"] = "Submit your research";
}

<div class="text-center">
    <h1 class="display-4">Submit Your research</h1>
    <form asp-controller="Submission" asp-action="Submit" method="post" enctype="multipart/form-data">
        <label>
            Name
            <input type="text" name="name" />
        </label>
        <label>
            Surname
            <input type="text" name="surname" />
        </label>
        <label>
            Email
            <input type="text" name="email" />
        </label>
        <label>
            Research Institution
            <input type="text" name="researchInstitution" />
        </label>
        <label>
            Research Paper
            <input type="file" name="file" />
        </label>
        <button type="submit">Submit</button>
    </form>
</div>
